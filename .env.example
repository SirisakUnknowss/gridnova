# ===== Gridnova — Environment Variables =====
# Copy this file to .env.local and fill in your values.
# Get local values from `supabase status` after `supabase start`.

# Supabase
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# App
VITE_APP_ENV=local                  # local | staging | production
VITE_APP_VERSION=dev

# Error tracking (optional in dev)
VITE_SENTRY_DSN=

# Server-only (Edge Functions) — set via `supabase secrets set`
# FCM_SERVER_KEY=
# SENTRY_DSN=
